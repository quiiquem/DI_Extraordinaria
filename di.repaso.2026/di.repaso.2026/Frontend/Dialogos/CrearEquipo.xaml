<mah:MetroWindow x:Class="di.repaso._2026.Frontend.Dialogos.CrearEquipo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:di.repaso._2026.Frontend.Dialogos"
        mc:Ignorable="d"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Icon="/Recursos/Iconos/pelota.png"
                    Height="550" Width="800"
                 Loaded="Equipos_Loaded"
        Title="AÑADIR EQUIPO">
    <Grid Background="#476db6">

        <!--Eclipse.-->
        <Canvas>
            <Ellipse Fill="#302f41" Canvas.Right="-350" Canvas.Top="-70" Width="700" Height="630"></Ellipse>
        </Canvas>
        <!--Login grid-->
        <Grid Margin="80,60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.24*"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <!--<StackPanel de la izquierda (imagen y tal)-->
            <StackPanel Grid.Column="0" Orientation="Vertical" Background="#302f41">
                <Image Source="/Recursos/Imagenes/login.jpg" Margin="0,100"/>
                <TextBlock FontSize="13" Text="AÑADIR EQUIPO" Foreground="White" FontWeight="DemiBold"
                           HorizontalAlignment="Center" Margin="0,-80,0,0"/>
                <Separator Width="70" Background="White" Height="1" Margin="0,-105,0,0"/>
            </StackPanel>

            <!--StackPanel de la derecha (Añadir equipo)-->
            <StackPanel Grid.Column="1" Orientation="Vertical" Background="White">
                <TextBlock FontSize="16" Text="AÑADIR EQUIPO" HorizontalAlignment="Center" FontWeight="DemiBold" Foreground="Black"
                           Margin="0,60"/>

                <TextBlock FontSize="12" Text="Por favor escriba sobre los campos necesarios" HorizontalAlignment="Center" Margin="0,-60" Foreground="Black"/>

                <!--Textboxes (Datos del equipo)-->
                <StackPanel Orientation="Horizontal" Height="35">

                    <TextBox Width="170" Height="35"  FontSize="12" VerticalContentAlignment="Center" Foreground="Gray" mah:TextBoxHelper.Watermark="Nombre de Equipo"  
                             Text="{Binding equipo.Nombre, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True, ValidatesOnDataErrors=True}"
          Background="#F5F5F5" mah:TextBoxHelper.ClearTextButton="True" Margin="50,0"/>

                    <TextBox  Width="170"  Height="35"  FontSize="12" VerticalContentAlignment="Center" Foreground="Gray" mah:TextBoxHelper.Watermark="Nombre de Ciudad" Margin="0,-50" 
                               Text="{Binding equipo.Ciudad, UpdateSourceTrigger=PropertyChanged, NotifyOnValidationError=True, ValidatesOnDataErrors=True}"
          Background="#F5F5F5" mah:TextBoxHelper.ClearTextButton="True"/>

                </StackPanel>

                <StackPanel Orientation="Horizontal" Height="35">

                    <ComboBox Width="170" Height="35"  FontSize="12" VerticalContentAlignment="Center" Foreground="Gray" mah:TextBoxHelper.Watermark="Conferencia" 
          Background="#F5F5F5" Margin="50,0" 
                              ItemsSource="{Binding listaConferencias}" 
                              SelectedItem="{Binding equipo.Conferencia, Mode=TwoWay, NotifyOnValidationError=True, ValidatesOnDataErrors=True}"/>

                    <ComboBox  Width="170"  Height="35"  FontSize="12" VerticalContentAlignment="Center" Foreground="Gray" mah:TextBoxHelper.Watermark="División" Margin="0,-50" 
          Background="#F5F5F5"  ItemsSource="{Binding listaDivisiones}"
                            SelectedItem="{Binding equipo.Division, Mode=TwoWay,  NotifyOnValidationError=True, ValidatesOnDataErrors=True}"/>

                </StackPanel>
                

                <!--Boton to flama asi gradiente-->
                <Button Content="CREAR EQUIPO" Width="270" Height="35" Margin="0,20" Click="crear_equipo"
        FontSize="11" Foreground="White" BorderThickness="0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Purple" Offset="0"/>
                            <GradientStop Color="DeepSkyBlue" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Separator Background="DarkOrange" Width="270" Margin="0,30"/>

                <!--Pelota.-->
                <Image Source="/Recursos/Iconos/pelota.png" HorizontalAlignment="Left" Width="30" Margin="-15,0"></Image>
            </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>
