<mah:MetroWindow x:Class="di.repaso._2026.Frontend.Dialogos.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:di.repaso._2026.Frontend.Dialogos"
                  xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
                   Icon="/Recursos/Iconos/pelota.png"
        ResizeMode="NoResize"
        Title="LOGIN"
        Height="550" Width="800">
    <Grid Background="#476db6">

        <!--Eclipse.-->
        <Canvas>
            <Ellipse Fill="#302f41" Canvas.Right="-350" Canvas.Top="-70" Width="700" Height="630"></Ellipse>
        </Canvas>
        <!--Login grid-->
        <Grid Margin="80,60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.24*"/>
                <ColumnDefinition Width="0.8*"/>
            </Grid.ColumnDefinitions>

            <!--<StackPanel de la izquierda (imagen y tal)-->
            <StackPanel Grid.Column="0" Orientation="Vertical" Background="#302f41">
                <Image Source="/Recursos/Imagenes/login.jpg" Margin="0,100"/>
                <TextBlock FontSize="13" Text="BIENVENIDOS" Foreground="White" FontWeight="DemiBold"
                           HorizontalAlignment="Center" Margin="0,-80,0,0"/>
                <Separator Width="70" Background="White" Height="1" Margin="0,-105,0,0"/>
            </StackPanel>

            <!--StackPanel de la derecha (inicio de sesión)-->
            <StackPanel Grid.Column="1" Orientation="Vertical" Background="White">
                <TextBlock FontSize="16" Text="INICIO DE SESIÓN" HorizontalAlignment="Center" FontWeight="DemiBold" Foreground="Black"
                           Margin="0,60"/>

                <TextBlock FontSize="12" Text="Por favor introduce sus credenciales" HorizontalAlignment="Center" Margin="0,-60" Foreground="Black"/>

                <!--Textboxes (nombre usuario/contraseña)-->

                <TextBox Width="270" Height="35"  FontSize="12" VerticalContentAlignment="Center" Foreground="Gray" mah:TextBoxHelper.Watermark="Nombre de Usuario" Margin="0,-50" 
                        Background="#F5F5F5" mah:TextBoxHelper.ClearTextButton="True"/>

                <PasswordBox Width="270" Height="35"  FontSize="12" VerticalContentAlignment="Center"  Foreground="Gray" mah:TextBoxHelper.Watermark="Clave de acceso" 
        Background="#F5F5F5" mah:TextBoxHelper.ClearTextButton="True" Margin="0,40"/>
                
                <!--Boton to flama asi gradiente-->
                <Button Content="INICIO DE SESIÓN" Width="270" Height="35" Margin="0,-20" Click="abrir"
        FontSize="11" Foreground="White" BorderThickness="0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#476db6" Offset="0"/>
                            <GradientStop Color="#5b8fd4" Offset="1"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>

                <Separator Background="DarkOrange" Width="270" Margin="0,30"></Separator>
         
                <StackPanel Orientation="Horizontal">

                    <!--Google-->
                    <Button Width="130" Height="30" Background="Transparent" BorderThickness="1" BorderBrush="#476db6"
                            Margin="100,0">
                        <Image Source="/Recursos/Iconos/google.png" Width="23" VerticalAlignment="Center" Height="30" Margin="0,-4"/>
                    </Button>
                    <!--Facebook-->
                    <Button Width="130" Height="30" Background="Transparent" BorderThickness="1" BorderBrush="#476db6"
         Margin="-100,0">
                        <Image Source="/Recursos/Iconos/facebook.png" Width="23" VerticalAlignment="Center" Height="30" Margin="0,-4"/>
                    </Button>
                </StackPanel>
                
                <!--Pelota.-->
                <Image Source="/Recursos/Iconos/pelota.png" HorizontalAlignment="Left" Width="30" Margin="-15,0"></Image>
            </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>
